{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "Ark.Tools",
      "description": "Ark Tools group",
      "matchSourceUrls": [
        "https://github.com/ARKlab/Ark.Tools"
      ]
    },
    {
      "groupName": "Reqnroll",
      "description": "Reqnroll group",
      "matchSourceUrls": [
        "https://github.com/reqnroll/Reqnroll"
      ]
    },
    {
      "groupName": "VitePWA",
      "description": "Vite PWA group",
      "matchSourceUrls": [
        "https://github.com/vite-pwa/**"
      ]
    },
    {
      "groupName": "NLog",
      "description": "NLog group",
      "matchSourceUrls": [
        "https://github.com/NLog/NLog"
      ]
    },
    {
      "groupName": "Asp.Versioning",
      "description": "Asp.Versioning group",
      "matchSourceUrls": [
        "https://github.com/dotnet/aspnet-api-versioning"
      ]
    }
  ]
}
